{
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "npm run development",
    "development": "NODE_ENV=development webpack --progress --config=node_modules/laravel-mix/setup/webpack.config.js",
    "watch": "NODE_ENV=development webpack --watch --progress --config=node_modules/laravel-mix/setup/webpack.config.js",
    "watch-poll": "npm run watch -- --watch-poll",
    "hot": "NODE_ENV=development webpack-dev-server --inline --hot --config=node_modules/laravel-mix/setup/webpack.config.js",
    "prod": "npm run production",
    "production": "NODE_ENV=production webpack --progress --config=node_modules/laravel-mix/setup/webpack.config.js && node scripts/apply-mix-manifest.js",
    "postinstall": "npm run production"
  },
  "devDependencies": {
    "animate.css": "^4.1.1",
    "browser-sync": "^3.0.4",
    "browser-sync-webpack-plugin": "^2.4.0",
    "howler": "^2.2.4",
    "laravel-mix": "^6.0.49",
    "motion": "^12.42.2",
    "sass": "^1.101.0",
    "sass-loader": "^17.0.0"
  }
}
